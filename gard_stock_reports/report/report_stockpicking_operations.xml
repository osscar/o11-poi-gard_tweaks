<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_pickslip">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <!-- Header Section -->
                        <div class="text-center" style="font-size:30px">
                            <h2><span t-field="o.company_id.razon"/></h2>
                            <h3>
                                <span>BOLETA DE ALMACÉN</span><br/>
                                <span t-field="o.category"/>
                            </h3>
                        </div>
                        <div style="border-bottom: 1px solid black;"></div>
                        <div style="font-size:30px" class="text-center">
                            <span t-field="o.picking_type_id.warehouse_id.name"/>
                            <span t-if="o.picking_type_id.warehouse_id"> : </span>
                            <span t-field="o.name"/>
                            <p t-if="o.origin"><span t-field="o.origin"/></p>
                        </div>
                        <br/>
                        
                        <!-- Client/Partner Info -->
                        <div class="row" style="font-size:25px">
                            <div t-if="not o.category == 'internal'">
                                <div t-if="o.partner_id" name="partner_header">
                                    <div t-if="o.partner_id.razon" style="font-weight:bold">
                                        <span t-field="o.partner_id.razon"/>
                                    </div>
                                    <div t-if="not o.partner_id.razon">
                                        <span t-field="o.partner_id.name"/>
                                    </div>
                                    <div t-if="o.partner_id.nit">NIT: <span t-field="o.partner_id.nit"/></div>
                                    <div t-field="o.partner_id"
                                         t-options='{"widget": "contact", "fields": ["address", "phone", "mobile"], "no_marker": True, "phone_icons": True}'/>
                                </div>
                            </div>
                        </div>
                        <p/>

                        <!-- Width-Optimized Move Table -->
                        <table t-if="o.move_line_ids" class="table table-condensed" style="font-size:25px; table-layout: fixed;">
                            <thead>
                                <tr>
                                    <th width="30%">Producto / ID</th>
                                    <th width="20%" class="text-center">Qty / Done</th>
                                    <th width="50%" colspan="2" style="padding:0;">
                                        <table width="100%" style="margin:0; table-layout: fixed;">
                                            <tr>
                                                <th width="50%" style="padding-left: 5px;">Source</th>
                                                <th width="50%">Destination</th>
                                            </tr>
                                        </table>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.move_lines.sorted(key=lambda m: m.product_id.id)" t-as="move">
                                    <td style="word-wrap: break-word; vertical-align: top;">
                                        <span t-field="move.product_id.display_name" style="font-weight:bold;"/><br/>
                                        <span t-field="move.product_id.description_picking" style="font-size: 18px; color: #444;"/>
                                        
                                        <!-- Barcode under product name to save width -->
                                        <div t-if="move.product_id.barcode" style="margin-top: 5px;">
                                            <img t-att-src="'/report/barcode/?type=Code128&amp;value=%s&amp;width=600&amp;height=50' % move.product_id.barcode"
                                                 style="width:100%;height:35px"/>
                                        </div>
                                    </td>
                                    <td class="text-center" style="vertical-align: top;">
                                        <!-- Unified Qty column with 2-decimal precision -->
                                        <span t-esc="'%.2f' % move.product_uom_qty"/> / 
                                        <span t-esc="'%.2f' % move.quantity_done"/>
                                        <div style="font-size: 20px; font-weight: bold; margin-top: 5px;">
                                            <span t-field="move.product_id.uom_id" groups="product.group_uom"/>
                                        </div>
                                    </td>
                                    <td colspan="2" style="padding:0; vertical-align: top;">
                                        <t t-if="move.move_line_ids">
                                            <table width="100%" style="table-layout: fixed; margin:0;">
                                                <tr t-foreach="move.move_line_ids.sorted(key=lambda ml: ml.location_id.id)" t-as="ml">
                                                    <td width="50%" style="padding: 2px 8px 2px 5px; word-wrap: break-word;">
                                                        <t t-if="o.picking_type_id.code != 'incoming'">
                                                            <span t-esc="ml.location_id.display_name"/>
                                                        </t>
                                                        <!-- Lot/Serial info under Source location -->
                                                        <div t-if="ml.lot_id or ml.lot_name" style="font-size: 18px; font-style: italic; color: #555;">
                                                            Lote: <span t-field="ml.lot_id"/><span t-field="ml.lot_name"/>
                                                        </div>
                                                    </td>
                                                    <td width="50%" style="padding: 2px 5px; word-wrap: break-word;">
                                                        <span t-field="ml.location_dest_id"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <!-- Signature Section -->
                        <br/><br/>
                        <table class="table table-condensed" style="font-size:30px">
                            <thead>
                                <tr>
                                    <th style="width:150px;"></th>
                                    <th>
                                        ---------------------------------------<br/>
                                        <strong>Responsable</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td></td>
                                    <td style="line-height: 11px;">
                                        <p>Nombre:</p><br/>
                                        <p>CI:</p><br/>
                                        <p>Fecha:</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>