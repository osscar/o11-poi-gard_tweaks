<odoo>
    <record id="view_payment_request_form_inherit_aml" model="ir.ui.view">
        <field name="name">account.payment.request.form.inherit.aml</field>
        <field name="model">account.payment.request</field>
        <field name="inherit_id" ref="poi_payment_request.view_account_payment_request_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Accounting Entries">
                    <field name="move_line_ids" readonly="1">
                        <tree>
                            <field name="date"/>
                            <field name="move_id"/>
                            <field name="journal_id"/>
                            <field name="account_id"/>
                            <field name="name"/>
                            <field name="debit" sum="Total Debit"/>
                            <field name="credit" sum="Total Credit"/>
                            <field name="balance"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>